<Application x:Class="FXRateDashboard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <Color x:Key="BrandBrightGreenColor">#9FE870</Color>
        <Color x:Key="BrandForestGreenColor">#163300</Color>
        <Color x:Key="SurfaceColor">#FBFCF8</Color>
        <Color x:Key="SurfaceAltColor">#F2F7EA</Color>
        <Color x:Key="PanelEdgeColor">#1F163300</Color>
        <Color x:Key="ContentPrimaryColor">#163300</Color>
        <Color x:Key="MutedTextColor">#6A745F</Color>
        <Color x:Key="PositiveColor">#6C9A54</Color>
        <Color x:Key="NegativeColor">#D97A68</Color>
        <Color x:Key="WarningColor">#C69200</Color>

        <SolidColorBrush x:Key="BrandBrightGreenBrush" Color="{StaticResource BrandBrightGreenColor}" />
        <SolidColorBrush x:Key="BrandForestGreenBrush" Color="{StaticResource BrandForestGreenColor}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
        <SolidColorBrush x:Key="PanelEdgeBrush" Color="{StaticResource PanelEdgeColor}" />
        <SolidColorBrush x:Key="ContentPrimaryBrush" Color="{StaticResource ContentPrimaryColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
        <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}" />
        <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource NegativeColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFFFFF" />
            <GradientStop Offset="1" Color="#F7FAF2" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#149FE870" />
            <GradientStop Offset="0.55" Color="#0A9FE870" />
            <GradientStop Offset="1" Color="#009FE870" />
        </LinearGradientBrush>

        <Style x:Key="WidgetTextButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E5F0D7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <sys:Double x:Key="WidgetWidth">404</sys:Double>
        <sys:Double x:Key="WidgetHeight">410</sys:Double>
    </Application.Resources>
</Application>
