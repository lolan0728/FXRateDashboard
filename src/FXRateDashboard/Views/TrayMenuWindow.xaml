<Window x:Class="FXRateDashboard.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ShowActivated="True"
        Topmost="True">
    <Window.Resources>
        <SolidColorBrush x:Key="MenuSurfaceBrush" Color="#1F2228" />
        <SolidColorBrush x:Key="MenuBorderBrush" Color="#343A44" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="MenuHoverBrush" Color="#2C313A" />
        <SolidColorBrush x:Key="MenuPressedBrush" Color="#353B46" />
        <SolidColorBrush x:Key="MenuDividerBrush" Color="#343943" />

        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="31" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource MenuPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="{DynamicResource MenuSurfaceBrush}"
            BorderBrush="{DynamicResource MenuBorderBrush}"
            BorderThickness="1"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="6"
                              Direction="270"
                              Color="#000000"
                              Opacity="0.38" />
        </Border.Effect>

        <StackPanel>
            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="ToggleVisibilityButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="12"
                          Height="12"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                        <Rectangle Width="10"
                                   Height="8"
                                   RadiusX="2"
                                   RadiusY="2"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   StrokeThickness="1.1" />
                        <Rectangle Width="10"
                                   Height="2"
                                   Margin="0,1,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Grid>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ToggleVisibilityMenuText}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="ToggleModeButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="12"
                             Height="12"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform"
                              Data="M2,10 L6,6 L9,8 L14,3" />
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ToggleModeMenuText}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="SettingsButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="12"
                             Height="12"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Data="M7,0 L8.1,0.5 L9.3,0.2 L10,1.1 L9.8,2.3 L10.5,3.1 L11.7,3.2 L12,4.4 L11.2,5.3 L11.4,6.5 L10.4,7.2 L9.3,6.9 L8.4,7.6 L8.3,8.8 L7.1,9.1 L6.3,8.2 L5.1,8.4 L4.4,7.4 L4.6,6.2 L3.9,5.3 L2.7,5.2 L2.4,4 L3.2,3.1 L3,1.9 L4,1.2 L5.1,1.5 L6,0.8 Z M7.1,2.7 A1.9,1.9 0 1 0 7.1,6.5 A1.9,1.9 0 1 0 7.1,2.7 Z" />
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="Settings"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="ToggleClickThroughButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="12"
                             Height="12"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center">
                        <Canvas Width="12" Height="12">
                            <Ellipse Canvas.Left="1.2"
                                     Canvas.Top="1.2"
                                     Width="9.6"
                                     Height="9.6"
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                     StrokeThickness="1.1" />
                            <Line X1="6" Y1="0.6" X2="6" Y2="2.2"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Line X1="6" Y1="9.8" X2="6" Y2="11.4"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Line X1="0.6" Y1="6" X2="2.2" Y2="6"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Line X1="9.8" Y1="6" X2="11.4" Y2="6"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Ellipse Canvas.Left="5.1"
                                     Canvas.Top="5.1"
                                     Width="1.8"
                                     Height="1.8"
                                     Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Canvas>
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ToggleClickThroughMenuText}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </Grid>
            </Button>

            <Border Height="1"
                    Margin="8,5,8,5"
                    Background="{DynamicResource MenuDividerBrush}" />

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="QuitButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="12"
                             Height="12"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center">
                        <Path Data="M3,3 L13,13 M13,3 L3,13"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform" />
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="Quit"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
