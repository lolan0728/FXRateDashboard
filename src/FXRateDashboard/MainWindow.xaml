<Window x:Class="FXRateDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FXRateDashboard.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:FXRateDashboard.Models"
        mc:Ignorable="d"
        Title="FX Rate Dashboard"
        Width="{DynamicResource WidgetWidth}"
        Height="{DynamicResource WidgetHeight}"
        MinWidth="{DynamicResource WidgetWidth}"
        MaxWidth="{DynamicResource WidgetWidth}"
        MinHeight="{DynamicResource WidgetHeight}"
        MaxHeight="{DynamicResource WidgetHeight}"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="False"
        Opacity="1"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="RangeButtonStyle" TargetType="Button" BasedOn="{StaticResource WidgetTextButtonStyle}">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="10"
                Background="{Binding PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelEdgeBrush}"
                BorderThickness="1"
                CornerRadius="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.18" Color="#2A163300" />
            </Border.Effect>
        </Border>

        <Border Margin="10"
                CornerRadius="28"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           Background="Transparent"
                           MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown">
                    <Border Background="{Binding AccentBrush}" CornerRadius="12" Padding="10,5">
                        <TextBlock Text="{Binding PairLabel}"
                                   Foreground="{Binding PrimaryTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Border DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Background="{Binding StatusChipBackgroundBrush}"
                            BorderBrush="{StaticResource PanelEdgeBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="8,4">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{Binding MutedTextBrush}"
                                   FontSize="11" />
                    </Border>
                </DockPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,8,0,0"
                            MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentRateDisplay}"
                                   Foreground="{Binding PrimaryTextBrush}"
                                   FontSize="42"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable Display" />
                        <TextBlock Margin="10,16,0,0"
                                   Text="{Binding QuoteCurrencyCode}"
                                   Foreground="{Binding MutedTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ChangeDisplay}"
                                   Foreground="{Binding TrendBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="8,0,0,0"
                                   Text="{Binding ChangePercentDisplay}"
                                   Foreground="{Binding TrendBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,8,0,10"
                        Padding="6,4,6,8"
                        Background="{Binding ChartCardBackgroundBrush}"
                        BorderBrush="{StaticResource PanelEdgeBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <controls:SparklineChart Margin="0"
                                             MinHeight="266"
                                             VerticalAlignment="Stretch"
                                             ItemsSource="{Binding ChartPoints}"
                                             StrokeBrush="{Binding TrendBrush}" />
                </Border>

                <DockPanel Grid.Row="3" LastChildFill="False">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="1D"
                                Command="{Binding SelectRangeCommand}"
                                CommandParameter="{x:Static models:TimeRangePreset.Day}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RangeButtonStyle}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Day}" />
                                                <Condition Binding="{Binding IsOffline}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{StaticResource BrandBrightGreenBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrightGreenBrush}" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Day}" />
                                                <Condition Binding="{Binding IsOffline}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#B7BEB2" />
                                            <Setter Property="Foreground" Value="#52584F" />
                                            <Setter Property="BorderBrush" Value="#B7BEB2" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="1W"
                                Command="{Binding SelectRangeCommand}"
                                CommandParameter="{x:Static models:TimeRangePreset.Week}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RangeButtonStyle}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Week}" />
                                                <Condition Binding="{Binding IsOffline}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{StaticResource BrandBrightGreenBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrightGreenBrush}" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Week}" />
                                                <Condition Binding="{Binding IsOffline}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#B7BEB2" />
                                            <Setter Property="Foreground" Value="#52584F" />
                                            <Setter Property="BorderBrush" Value="#B7BEB2" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="1M"
                                Command="{Binding SelectRangeCommand}"
                                CommandParameter="{x:Static models:TimeRangePreset.Month}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RangeButtonStyle}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Month}" />
                                                <Condition Binding="{Binding IsOffline}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{StaticResource BrandBrightGreenBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrightGreenBrush}" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Month}" />
                                                <Condition Binding="{Binding IsOffline}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#B7BEB2" />
                                            <Setter Property="Foreground" Value="#52584F" />
                                            <Setter Property="BorderBrush" Value="#B7BEB2" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="1Y"
                                Margin="0"
                                Command="{Binding SelectRangeCommand}"
                                CommandParameter="{x:Static models:TimeRangePreset.Year}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RangeButtonStyle}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Year}" />
                                                <Condition Binding="{Binding IsOffline}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{StaticResource BrandBrightGreenBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BrandBrightGreenBrush}" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ActiveRange}" Value="{x:Static models:TimeRangePreset.Year}" />
                                                <Condition Binding="{Binding IsOffline}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#B7BEB2" />
                                            <Setter Property="Foreground" Value="#52584F" />
                                            <Setter Property="BorderBrush" Value="#B7BEB2" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Right"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Text="Wise"
                               Foreground="{Binding MutedTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
